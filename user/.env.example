# --- Shop Builder REST API (dashboard CRUD) ---
# When USE_MOCK is true (default), the app uses bundled seeds and never calls the API.
NEXT_PUBLIC_SHOP_BUILDER_USE_MOCK=true
# Base URL for your backend (no trailing slash). Example: http://localhost:4000
NEXT_PUBLIC_SHOP_BUILDER_API_URL=

# --- Platform worker (existing login / merchant flows) ---
# Required only if you use password login against the platform API.
NEXT_PUBLIC_PLATFORM_API_URL=

# --- Backend only (not read by this Next app) ---
# Use in your API repo with Drizzle / Prisma / etc.
# DATABASE_URL=postgresql://user:pass@localhost:5432/shop_builder
